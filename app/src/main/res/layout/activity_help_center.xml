<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"
    android:layout_height="match_parent"
    tools:context=".activity.HelpCenterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_16sdp"
        android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/ib_back"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:background="@drawable/custom_rounded_nav"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/onBackground"

            />

        <TextView
            android:layout_width="@dimen/_150sdp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="@color/onBackground"
            android:gravity="center"
            android:layout_marginStart="@dimen/_35sdp"
            android:text="@string/str_help_center"
            android:textSize="@dimen/_18sdp" />

    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="@dimen/_260sdp"
        android:layout_height="@dimen/_50sdp"
        android:layout_marginTop="@dimen/_32sdp"
        android:textColorHint="@color/onBackground"
        android:hint="@string/str_customer_service">

        <AutoCompleteTextView
            android:id="@+id/auto_dropdown_customer_services"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/custum_rounded"
            android:clickable="true"
            android:drawableStart="@drawable/ic_head_phone"
            android:drawablePadding="@dimen/_8sdp"
            android:cursorVisible="false"
            android:focusable="true"
            android:inputType="none"
            android:textSize="@dimen/_11ssp"
            tools:ignore="SpeakableTextPresentCheck,VisualLintTextFieldSize" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="@dimen/_260sdp"
        android:layout_height="@dimen/_50sdp"
        android:imeOptions="actionNext"
        android:layout_marginTop="@dimen/_12sdp"
        android:textColorHint="@color/onBackground"
        android:hint="@string/str_whatsapp">

        <AutoCompleteTextView
            android:id="@+id/auto_dropdown_whatsapp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/custum_rounded"
            android:clickable="true"
            android:imeOptions="actionNext"
            android:drawableStart="@drawable/ic_phone"
            android:drawablePadding="@dimen/_8sdp"
            android:cursorVisible="false"
            android:focusable="true"
            android:inputType="none"
            android:textSize="@dimen/_11ssp"
            tools:ignore="SpeakableTextPresentCheck,VisualLintTextFieldSize" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="@dimen/_260sdp"
        android:layout_height="@dimen/_50sdp"
        android:imeOptions="actionNext"
        android:layout_marginTop="@dimen/_12sdp"
        android:textColorHint="@color/onBackground"
        android:hint="@string/str_website">

        <AutoCompleteTextView
            android:id="@+id/auto_dropdown_website"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/custum_rounded"
            android:clickable="true"
            android:imeOptions="actionNext"
            android:drawableStart="@drawable/ic_globle"
            android:drawablePadding="@dimen/_8sdp"
            android:cursorVisible="false"
            android:focusable="true"
            android:inputType="none"
            android:textSize="@dimen/_11ssp"
            tools:ignore="SpeakableTextPresentCheck,VisualLintTextFieldSize" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="@dimen/_260sdp"
        android:layout_height="@dimen/_50sdp"
        android:imeOptions="actionNext"
        android:layout_marginTop="@dimen/_12sdp"
        android:textColorHint="@color/onBackground"
        android:hint="@string/str_instagram">

        <AutoCompleteTextView
            android:id="@+id/auto_dropdown_instagram"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/custum_rounded"
            android:clickable="true"
            android:imeOptions="actionNext"
            android:drawableStart="@drawable/ic_camera"
            android:drawablePadding="@dimen/_8sdp"
            android:cursorVisible="false"
            android:focusable="true"
            android:inputType="none"
            android:textSize="@dimen/_11ssp"
            tools:ignore="SpeakableTextPresentCheck,VisualLintTextFieldSize" />
    </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</LinearLayout>