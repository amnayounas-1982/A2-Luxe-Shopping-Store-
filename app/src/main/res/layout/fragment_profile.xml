<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:id="@+id/fragment_container"
    android:background="?android:attr/windowBackground"
    tools:context=".fragment.ProfileFragment"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_margin="@dimen/_16sdp"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/ib_back"
                android:layout_width="@dimen/_30sdp"
                android:layout_height="@dimen/_30sdp"
                android:background="@drawable/custom_rounded_nav"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/onBackground"
                tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/_85sdp"
                android:textColor="@color/onBackground"
                android:text="@string/str_profile"
                android:textSize="@dimen/_18sdp" />

        </LinearLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_item1"
            android:layout_width="@dimen/_100sdp"
            android:layout_height="@dimen/_100sdp"
            android:layout_marginStart="@dimen/_5sdp"
            android:layout_marginTop="@dimen/_15sdp"
            android:scaleType="centerCrop"
            android:layout_gravity="center"
            android:src="@drawable/img"
            app:shapeAppearanceOverlay="@style/RoundedBottomApp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/onBackground"
            android:layout_marginTop="@dimen/_2ssp"
            android:text="@string/str_Name"
            android:textSize="@dimen/_18sdp" />



    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="@dimen/_38sdp"
        android:layout_marginTop="@dimen/_15sdp">

        <TextView
            android:id="@+id/tv_my_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_person1"
            android:drawablePadding="@dimen/_5sdp"
            app:tint="@color/iconTint"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:text="@string/str_my_profile"
            android:textColor="@color/onBackground"
            android:layout_gravity="center"
            android:textSize="@dimen/_15sdp" />

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="@dimen/_38sdp"
        android:layout_marginTop="@dimen/_15sdp">

        <TextView
            android:id="@+id/tv_my_orders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_mY_orders"
            android:drawableStart="@drawable/ic_order"
            android:drawablePadding="@dimen/_5sdp"
            android:textColor="@color/onBackground"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:layout_gravity="center"
            android:textSize="@dimen/_15sdp" />

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="@dimen/_38sdp"
        android:layout_marginTop="@dimen/_15sdp">

        <TextView
            android:id="@+id/tv_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_Settings"
            android:textColor="@color/onBackground"
            android:drawableStart="@drawable/ic_settings"
            android:drawablePadding="@dimen/_5sdp"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:layout_gravity="center"
            android:textSize="@dimen/_15sdp" />

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="@dimen/_38sdp"
        android:layout_marginTop="@dimen/_15sdp">

        <TextView
            android:id="@+id/tv_help"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_Help_center"
            android:textColor="@color/onBackground"
            android:drawableStart="@drawable/ic_help"
            android:drawablePadding="@dimen/_5sdp"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:layout_gravity="center"
            android:textSize="@dimen/_15sdp" />

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="@dimen/_38sdp"
        android:layout_marginTop="@dimen/_15sdp">

        <TextView
            android:id="@+id/tv_privacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/str_Privacy_policy"
            android:drawableStart="@drawable/ic_lock"
            android:drawablePadding="@dimen/_5sdp"
            android:textColor="@color/onBackground"
            android:drawableEnd="@drawable/ic_arrow_right"
            android:layout_gravity="center"
            android:textSize="@dimen/_15sdp" />

    </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="@dimen/_38sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:layout_marginTop="@dimen/_15sdp">

            <TextView
                android:id="@+id/btn_log_out"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/str_Logout"
                android:drawableStart="@drawable/ic_logout"
                android:drawablePadding="@dimen/_5sdp"
                android:textColor="@color/onBackground"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:layout_gravity="center"
                android:textSize="@dimen/_15sdp" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</LinearLayout>